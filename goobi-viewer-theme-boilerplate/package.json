{
  "name": "goobi-viewer-theme-boilerplate",
  "version": "3.4.0",
  "description": "This is a theme template for the Goobi viewer.",
  "author": "intranda GmbH",
  "repository": {
    "type": "git",
    "url": "https://gitea.intranda.com/goobi-viewer/goobi-viewer-theme-boilerplate.git"
  },
  "license": "GPL-2.0-or-later",
  "scripts": {
    "dev": "cross-env GV_AUTOPREFIX=0 NODE_NO_WARNINGS=1 gulp dev",
    "build": "cross-env GV_AUTOPREFIX=0 NODE_NO_WARNINGS=1 gulp build",
    "sync": "cross-env GV_AUTOPREFIX=0 NODE_NO_WARNINGS=1 gulp sync-all",
    "cache": "cross-env GV_AUTOPREFIX=0 NODE_NO_WARNINGS=1 gulp cache",
    "target": "cross-env GV_AUTOPREFIX=0 NODE_NO_WARNINGS=1 gulp target",
	"prepare": "node ../scripts/pre-commit/install.js",
	"format": "prettier --write .",
	"test:hooks": "jest --passWithNoTests"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
	"ansi-colors": "^4.1.3",
	"autoprefixer": "^10.4.20",
	"cheerio": "^1.0.0",
	"cross-env": "^10.0.0",
	"del": "^8.0.0",
	"fancy-log": "^2.0.0",
	"gulp": "^4.0.2",
	"gulp-concat": "^2.6.1",
	"gulp-header": "^2.0.9",
	"gulp-less": "^5.0.0",
	"gulp-plumber": "^1.2.1",
	"gulp-postcss": "^9.0.1",
	"gulp-rename": "^2.1.0",
	"gulp-riot": "^1.1.5",
	"gulp-sourcemaps": "^3.0.0",
	"gulp-svgmin": "^4.1.0",
	"gulp-terser": "^1.2.0",
	"jest": "^29.0.0",
	"lefthook": "^2.0.14",
	"merge-stream": "^2.0.0",
	"pixl-xml": "^1.0.13",
	"postcss": "^8.4.47",
	"postcss-reporter": "^7.1.0",
	"prettier": "^3.7.4",
	"rollup": "^4.52.4",
	"through2": "^4.0.2"
  },
  "jest": {
    "rootDir": "..",
    "testMatch": [
      "<rootDir>/scripts/pre-commit/__tests__/**/*.test.js"
    ]
  },
  "browserslist": [
    ">0.5%",
    "last 2 versions",
    "Firefox ESR",
    "not dead"
  ]
}